{
  "name": "mobile-forex-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mobile test-automation portfolio project: a responsive-web forex-demo SUT driven by Playwright mobile emulation, with a Vitest-tested pure P&L core.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.13.3",
    "eslint": "^10.7.0",
    "eslint-plugin-playwright": "^2.10.5",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.10"
  }
}
